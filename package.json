{
  "name": "sm2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <27"
  },
  "scripts": {
    "dev": "node scripts/next-dev.cjs --webpack",
    "dev:turbopack": "node scripts/next-dev.cjs --turbopack",
    "dev:unlock": "node -e \"try{require('fs').unlinkSync('.next/dev/lock');console.log('Removed .next/dev/lock')}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "tokens:colors": "node scripts/generate-color-primitives.js",
    "tokens:typography": "node scripts/generate-typography.js",
    "tokens:layout": "node scripts/generate-layout-primitives.js",
    "tokens:theme": "node scripts/generate-theme-primitives.js",
    "map-markers:extract": "node scripts/extract-map-marker-svgs.mjs",
    "postinstall": "node scripts/copy-cesium-assets.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/text": "^3.12.0",
    "cesium": "^1.140.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gifenc": "^1.0.3",
    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.20.0",
    "maplibre-gl": "^5.22.0",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agentation": "^2.3.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^4.0.8",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
